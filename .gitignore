# Keep upstream clones out of the root repository history.
# Local wrapper docs beside each repo/ directory are tracked.
**/repo/

# Legacy local environments and logs. Current local state lives under .local/.
/envs/
/logs/
/.local/**

# Legacy generated smoke outputs. Current smoke outputs live under .local/smoke/.
/smoke/

# Test and tool caches.
/.pytest_cache/
/.mypy_cache/
/.ruff_cache/
/htmlcov/

# Common local caches.
__pycache__/
*.pyc
.DS_Store

# Repository-local installed binaries that should not be committed.
/bin/plantuml.jar
