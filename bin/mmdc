#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [ -x "$ROOT/.local/envs/puppeteer-cache/chrome-headless-shell/linux-148.0.7778.97/chrome-headless-shell-linux64/chrome-headless-shell" ]; then
  export PUPPETEER_EXECUTABLE_PATH="${PUPPETEER_EXECUTABLE_PATH:-$ROOT/.local/envs/puppeteer-cache/chrome-headless-shell/linux-148.0.7778.97/chrome-headless-shell-linux64/chrome-headless-shell}"
else
  export PUPPETEER_EXECUTABLE_PATH="${PUPPETEER_EXECUTABLE_PATH:-/usr/bin/chromium-browser}"
fi

for arg in "$@"; do
  case "$arg" in
    -h|--help|-V|--version|--puppeteerConfigFile|-p)
      exec "$ROOT/.local/envs/npm-prefix/bin/mmdc" "$@"
      ;;
  esac
done

for arg in "$@"; do
  case "$arg" in
    --puppeteerConfigFile=*|-p=*)
      exec "$ROOT/.local/envs/npm-prefix/bin/mmdc" "$@"
      ;;
  esac
done

if [ -f "$ROOT/scripts/mermaid-puppeteer-config.json" ]; then
  exec "$ROOT/.local/envs/npm-prefix/bin/mmdc" -p "$ROOT/scripts/mermaid-puppeteer-config.json" "$@"
fi

exec "$ROOT/.local/envs/npm-prefix/bin/mmdc" "$@"
